DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=YOUR_USERNAME.pythonanywhere.com,www.your-domain.com,your-domain.com
DJANGO_TIME_ZONE=Africa/Tripoli

DB_ENGINE=mysql
DB_NAME=YOUR_USERNAME$techmaintenance
DB_USER=YOUR_USERNAME
DB_PASSWORD=your-pythonanywhere-mysql-password
DB_HOST=YOUR_USERNAME.mysql.pythonanywhere-services.com
DB_PORT=3306

FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN/
CORS_ALLOWED_ORIGINS=https://YOUR_FRONTEND_DOMAIN,https://YOUR_USERNAME.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=https://YOUR_FRONTEND_DOMAIN,https://YOUR_USERNAME.pythonanywhere.com,https://*.pythonanywhere.com

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=0

JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7

# Transactional email for OTP and assignment notifications.
# Use "brevo", "cloudflare", "smtp", "auto", or "disabled".
ASSIGNMENT_EMAIL_PROVIDER=auto
DEFAULT_FROM_EMAIL=EngiFlow <notifications@your-domain.com>
EMAIL_TIMEOUT=12

# Brevo Transactional Email API. Verify BREVO_FROM_ADDRESS once in Brevo;
# no Gmail password or app password is stored by this project.
BREVO_API_KEY=
BREVO_FROM_ADDRESS=
BREVO_FROM_NAME=EngiFlow
BREVO_REPLY_TO=

# Cloudflare Email Sending REST API (preferred when your sending domain is
# enabled and verified in Cloudflare).
CLOUDFLARE_EMAIL_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_FROM_ADDRESS=notifications@your-domain.com
CLOUDFLARE_EMAIL_FROM_NAME=EngiFlow
CLOUDFLARE_EMAIL_REPLY_TO=support@your-domain.com

# SMTP fallback. Leave EMAIL_HOST empty when Cloudflare is used.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Email OTP portals for companies and engineers.
PORTAL_OTP_TTL_MINUTES=5
PORTAL_OTP_MAX_ATTEMPTS=5
PORTAL_OTP_COOLDOWN_SECONDS=60
PORTAL_SESSION_MAX_AGE_SECONDS=2592000
PORTAL_OTP_EXPOSE_CODE=False
